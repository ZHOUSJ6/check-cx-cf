# ── Turso (libSQL) ──────────────────────────────────────────────
# Get these from https://turso.tech after `turso db create` + `turso db tokens create`.
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# ── Phase-1 Better Auth (scaffold; login UI is phase 2) ─────────
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=https://cx.020212.xyz

# ── GitHub OAuth (phase-2 admin login) ─────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Bootstrap admin emails (comma-sep; auto-granted admin role on first login) ──
ADMIN_EMAILS=admin@example.com

# ── Internal cache-metrics endpoint gate ────────────────────────
INTERNAL_METRICS_TOKEN=

# ── Turso (libSQL) ──────────────────────────────────────────────
# Get these from https://turso.tech after `turso db create` + `turso db tokens create`.
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# ── Deploy domain (for custom domain setup) ─────────────────────
# Leave empty to use *.workers.dev, or set your domain:
#   DEPLOY_DOMAIN=cx.example.com
# Then deploy with: DEPLOY_DOMAIN=cx.example.com pnpm deploy
DEPLOY_DOMAIN=

# ── Better Auth ─────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=https://your-domain.workers.dev

# ── GitHub OAuth (admin login) ──────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Bootstrap admin emails (comma-sep) ──────────────────────────
ADMIN_EMAILS=admin@example.com

# ── Internal cache-metrics endpoint gate ────────────────────────
INTERNAL_METRICS_TOKEN=
